# Discord bot setup
# Obtain from Discord Developer Portal > Bot > Token
DISCORD_BOT_TOKEN=
# Numeric ID of the Discord channel where the bot posts
CHANNEL_ID=

# --- Optional configuration (defaults shown) ---

# Minimum notional USD to trigger a notification
# MIN_NOTIONAL_USD=100

# Maximum emoji count in a message
# MAX_EMOJIS=80

# Include Hyperliquid TX link in messages (exposes wallet activity)
# INCLUDE_TX_LINK=false

# Position detection mode:
#   trade_activity  — report all trades above threshold (default)
#   strict_open     — only report confirmed position opens (uses userFillsByTime)
# POSITION_MODE=trade_activity
